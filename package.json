{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "deploy:vps": "bash scripts/deploy-vps.sh",
    "logs:vps": "ssh ${REMOTE_SSH_HOST:-praha112} \"pm2 logs ${REMOTE_APP_NAME:-praha112} --lines 200 --nostream\"",
    "logs:vps:live": "ssh -t ${REMOTE_SSH_HOST:-praha112} \"pm2 logs ${REMOTE_APP_NAME:-praha112} --lines 100\"",
    "logs:vps:error": "ssh ${REMOTE_SSH_HOST:-praha112} \"tail -n 200 ~/.pm2/logs/${REMOTE_APP_NAME:-praha112}-error.log\"",
    "logs:vps:out": "ssh ${REMOTE_SSH_HOST:-praha112} \"tail -n 200 ~/.pm2/logs/${REMOTE_APP_NAME:-praha112}-out.log\"",
    "logs:vps:nginx": "ssh ${REMOTE_SSH_HOST:-praha112} \"sudo tail -n 200 /var/log/nginx/error.log\"",
    "logs:vps:obs": "ssh ${REMOTE_SSH_HOST:-praha112} \"grep -h 'API write observation' ~/.pm2/logs/${REMOTE_APP_NAME:-praha112}-out.log | tail -n 200\"",
    "test": "npm run test:integration:all",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "ocr:warmup": "node scripts/warmup-ocr-languages.mjs",
    "score:backfill": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --env-file=.env scripts/backfill-score-events.mjs",
    "user:add": "node --env-file=.env scripts/add-user.mjs",
    "user:remove:remote": "node scripts/remove-remote-user.mjs",
    "users:seed:random": "node --env-file=.env scripts/seed-random-users.mjs",
    "r2:smoke": "node --env-file=.env scripts/r2-upload-download-smoke.mjs",
    "test:integration:core": "node --env-file=.env scripts/test-integration-core-flows.mjs",
    "test:integration:all": "npm run test:integration:core && npm run test:leaderboard:tie && npm run test:teams:concurrency",
    "test:teams:concurrency": "node --env-file=.env scripts/test-team-concurrency.mjs",
    "test:leaderboard:tie": "node --env-file=.env scripts/test-leaderboard-tie-ranking.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@prisma/client": "^6.16.2",
    "@tensorflow-models/blazeface": "^0.1.0",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "bcryptjs": "^3.0.3",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.16.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
