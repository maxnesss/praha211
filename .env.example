DATABASE_URL="postgresql://postgres:postgres@localhost:5432/praha211?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
RESEND_API_KEY="re_replace-with-resend-api-key"
RESEND_FROM="PRAHA 112 <no-reply@email.praha112.cz>"
# Volitelné: příjemce zpráv z /kontaktujte-nas (pokud chybí, použije se adresa z RESEND_FROM)
RESEND_CONTACT_TO="kontakt@email.praha112.cz"
# Volitelné: Umami analytics (načte se pouze po volbě "Povolit analytiku")
NEXT_PUBLIC_UMAMI_SCRIPT_URL="https://analytics.example.com/script.js"
NEXT_PUBLIC_UMAMI_WEBSITE_ID="replace-with-umami-website-id"
# Produkce pro tuto aplikaci:
# NEXTAUTH_URL="https://www.praha112.cz"
# NEXT_PUBLIC_SITE_URL="https://www.praha112.cz"
# Produkce: povinné pro přístup na /api/health/db přes hlavičku x-health-check-secret
HEALTHCHECK_SECRET="replace-with-healthcheck-secret"
# Produkce: povinné pro přístup na centrální cron endpoint /api/cron přes hlavičku x-cron-secret
CRON_SECRET="replace-with-cron-secret"
# Volitelné: po kolika ms považovat zaseknutou VALIDATING žádost za stale lock (default 600000 = 10 min)
CLAIM_VALIDATION_LOCK_STALE_MS="600000"

# Cloudflare R2 (privátní selfie upload/download)
R2_ACCOUNT_ID="replace-with-cloudflare-account-id"
R2_ACCESS_KEY_ID="replace-with-r2-access-key-id"
R2_SECRET_ACCESS_KEY="replace-with-r2-secret-access-key"
R2_BUCKET_NAME="replace-with-existing-r2-bucket-name"
# Volitelné: pokud prázdné, runtime použije https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT="https://replace-with-account-id.r2.cloudflarestorage.com"
